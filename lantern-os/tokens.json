{
  "$schema": "https://design-tokens.org/schema.json",
  "$description": "Lantern OS design tokens. Flat, low-contrast, calm. Brand-agnostic — apply to any product.",
  "color": {
    "bg": {
      "page":          { "value": "#FAFAF7", "darkValue": "#16182A", "description": "Paper white with a subtle dotted pattern overlay." },
      "surface":       { "value": "#FFFFFF", "darkValue": "#1D2034" },
      "surfaceHover":  { "value": "#F3F3EF", "darkValue": "#242842" },
      "surfacePress":  { "value": "#EAEAE5", "darkValue": "#2C3150" },
      "raised":        { "value": "#FFFFFF", "darkValue": "#232742" },
      "inset":         { "value": "#F0F0EB", "darkValue": "#14162A" },
      "pattern":       { "value": "radial-gradient(circle at center, rgba(42, 37, 32, 0.06) 1px, transparent 1.4px) 20px 20px", "description": "Subtle dotted overlay applied to bg-page only." }
    },
    "fg": {
      "1":           { "value": "#2A2520", "darkValue": "#E8E6DF" },
      "2":           { "value": "#6B6358", "darkValue": "#A0A4B5" },
      "3":           { "value": "#9B9485", "darkValue": "#6F7388" },
      "4":           { "value": "#C2BCAB", "darkValue": "#3F4258" },
      "onPrimary":   { "value": "#FBF6E7", "darkValue": "#16182A" }
    },
    "border": {
      "1": { "value": "#E6E4DC", "darkValue": "#2D3145" },
      "2": { "value": "#CFCCC2", "darkValue": "#3F4360" },
      "3": { "value": "#2A2520", "darkValue": "#E8E6DF" }
    },
    "brand": {
      "primary":       { "value": "#C97D4E", "darkValue": "#E0A07A", "description": "Copper-amber in light, lit copper in dark." },
      "primaryHover":  { "value": "#B86A3D", "darkValue": "#ECAE89" },
      "primaryPress":  { "value": "#9E5A33", "darkValue": "#CC8E6C" },
      "primaryTint":   { "value": "#F4E1CB", "darkValue": "#3A2A1F" },
      "secondary":     { "value": "#7C9B7B", "darkValue": "#9BC4B0", "description": "Sage — calming counterweight." },
      "secondaryTint": { "value": "#E2EADD", "darkValue": "#243A33" }
    },
    "semantic": {
      "success":      { "value": "#5E8060", "darkValue": "#9BC4B0" },
      "successTint":  { "value": "#DDE6D8", "darkValue": "#243A33" },
      "info":         { "value": "#7A95B8", "darkValue": "#9DB4D2" },
      "infoTint":     { "value": "#DFE6EE", "darkValue": "#232E3F" },
      "warning":      { "value": "#B58F4E", "darkValue": "#D9AE7A" },
      "warningTint":  { "value": "#ECDFBE", "darkValue": "#3A2F22" },
      "danger":       { "value": "#A14538", "darkValue": "#C98873" },
      "dangerTint":   { "value": "#ECD0C9", "darkValue": "#3D2922" }
    }
  },
  "typography": {
    "family": {
      "display": { "value": "'Newsreader', Georgia, serif", "description": "High-contrast literary serif. Use bold roman + italic together for the system's display look." },
      "sans":    { "value": "'DM Sans', -apple-system, sans-serif" },
      "mono":    { "value": "'Geist Mono', 'SF Mono', Menlo, monospace" }
    },
    "weight": {
      "regular":  { "value": 400 },
      "medium":   { "value": 500 },
      "semibold": { "value": 600 }
    },
    "scale": {
      "displayXL": { "fontSize": 72, "lineHeight": 1.05, "family": "display", "tracking": "-0.02em" },
      "displayL":  { "fontSize": 56, "lineHeight": 1.08, "family": "display", "tracking": "-0.015em" },
      "displayM":  { "fontSize": 40, "lineHeight": 1.12, "family": "display", "tracking": "-0.01em" },
      "h1":        { "fontSize": 32, "lineHeight": 1.18, "family": "display" },
      "h2":        { "fontSize": 24, "lineHeight": 1.22, "family": "display" },
      "h3":        { "fontSize": 20, "lineHeight": 1.30, "family": "display" },
      "h4":        { "fontSize": 17, "lineHeight": 1.35, "family": "sans", "weight": "semibold" },
      "bodyL":     { "fontSize": 17, "lineHeight": 1.55, "family": "sans" },
      "body":      { "fontSize": 15, "lineHeight": 1.55, "family": "sans" },
      "bodyS":     { "fontSize": 13, "lineHeight": 1.50, "family": "sans" },
      "caption":   { "fontSize": 12, "lineHeight": 1.45, "family": "sans" },
      "monoData":  { "fontSize": 13, "lineHeight": 1.40, "family": "mono", "features": "tnum" },
      "eyebrow":   { "fontSize": 11, "lineHeight": 1.40, "family": "sans", "weight": "medium", "tracking": "0.08em", "case": "upper" }
    }
  },
  "spacing": {
    "0":  { "value": 0 },
    "1":  { "value": 4 },
    "2":  { "value": 8 },
    "3":  { "value": 12 },
    "4":  { "value": 16 },
    "5":  { "value": 20 },
    "6":  { "value": 24 },
    "7":  { "value": 32 },
    "8":  { "value": 40 },
    "9":  { "value": 48 },
    "10": { "value": 64 },
    "11": { "value": 80 },
    "12": { "value": 96 }
  },
  "radius": {
    "0":    { "value": 0,   "description": "rules, dividers" },
    "1":    { "value": 4,   "description": "tight controls — chips, small inputs" },
    "2":    { "value": 8,   "description": "default — cards, surfaces, buttons" },
    "3":    { "value": 12,  "description": "large surfaces — hero panels, modals" },
    "4":    { "value": 16,  "description": "big banners, marketing blocks" },
    "pill": { "value": 999, "description": "pills, dots, avatars" }
  },
  "border": {
    "width": { "value": 1, "description": "hairline; no other widths are used" }
  },
  "elevation": {
    "0": { "value": "none", "description": "default — surfaces use borders, not shadows" },
    "1": { "value": "0 1px 2px rgba(42, 42, 38, 0.04), 0 0 0 1px rgba(42, 42, 38, 0.04)", "description": "popovers, toasts only" }
  },
  "motion": {
    "easing": {
      "calm": { "value": "cubic-bezier(0.32, 0.72, 0, 1)" }
    },
    "duration": {
      "fast": { "value": 120, "description": "hovers" },
      "base": { "value": 200, "description": "state changes" },
      "slow": { "value": 280, "description": "layout" }
    }
  },
  "layout": {
    "contentMax": { "value": 1200 },
    "sidebar":    { "value": 248 },
    "topbar":     { "value": 56 },
    "grid": {
      "columns":   { "value": 12 },
      "gutterDesktop": { "value": 24 },
      "gutterMobile":  { "value": 16 }
    }
  }
}
